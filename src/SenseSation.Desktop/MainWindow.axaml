<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:SenseSation.Desktop.ViewModels"
        xmlns:core="clr-namespace:SenseSation.Core.Models;assembly=SenseSation.Core"
        xmlns:train="clr-namespace:SenseSation.Core.Training;assembly=SenseSation.Core"
        xmlns:ctl="clr-namespace:SenseSation.Desktop.Controls"
        x:Class="SenseSation.Desktop.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="SenseSation" Width="1280" Height="820"
        MinWidth="980" MinHeight="640"
        Background="{StaticResource BgBrush}">

    <Window.DataTemplates>

        <!-- Match row (auto-applied to MatchSummary items) — click to open detail -->
        <DataTemplate DataType="core:MatchSummary">
            <Button Classes="flat" ToolTip.Tip="Review this match"
                    Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).ShowMatchCommand}"
                    CommandParameter="{Binding MatchId}">
                <Border Classes="row">
                    <Grid ColumnDefinitions="80,*,*,70,110,55,60">
                        <TextBlock Text="{Binding ResultLabel}" FontWeight="Black"
                                   Foreground="{Binding Result, Converter={x:Static vm:Conv.ResultBrush}}"/>
                        <TextBlock Grid.Column="1" Text="{Binding Agent}"/>
                        <TextBlock Grid.Column="2" Text="{Binding Map}"/>
                        <TextBlock Grid.Column="3" Text="{Binding ScoreLabel}" Classes="muted"/>
                        <TextBlock Grid.Column="4" Text="{Binding KdaLabel}"/>
                        <TextBlock Grid.Column="5" Text="{Binding You.HeadshotPct, StringFormat='{}{0}%'}" Classes="muted"/>
                        <TextBlock Grid.Column="6" Text="{Binding You.DamagePerRound}" Classes="muted" TextAlignment="Right"/>
                    </Grid>
                </Border>
            </Button>
        </DataTemplate>


        <!-- ===== Dashboard ===== -->
        <DataTemplate DataType="vm:DashboardVm">
            <ScrollViewer Padding="30" HorizontalScrollBarVisibility="Disabled">
                <StackPanel Spacing="16" MaxWidth="{Binding $parent[ScrollViewer].Bounds.Width}">
                    <Grid ColumnDefinitions="*,Auto,Auto">
                        <StackPanel>
                            <TextBlock Classes="h1" Text="DASHBOARD"/>
                            <TextBlock Classes="muted" Text="{Binding Headline}" TextWrapping="Wrap" MaxWidth="760"/>
                        </StackPanel>
                        <Border Grid.Column="1" Classes="chip" VerticalAlignment="Top" Margin="0,4,10,0">
                            <TextBlock Text="{Binding Session}" FontWeight="SemiBold" FontSize="12"
                                       Foreground="{DynamicResource Accent2Brush}"/>
                        </Border>
                        <Button Grid.Column="2" Classes="icon" Content="↻" ToolTip.Tip="Refresh Data" VerticalAlignment="Top"
                                Command="{Binding RefreshCommand}"/>
                    </Grid>

                    <!-- hero -->
                    <Border Classes="card">
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <StackPanel Spacing="6" HorizontalAlignment="Center" Margin="0,0,8,0">
                                <Border Width="112" Height="112" CornerRadius="56" BorderThickness="7"
                                        BorderBrush="{DynamicResource AccentBrush}" Background="#FF0A1219">
                                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="1">
                                        <Image Source="{Binding Tier, Converter={x:Static vm:Conv.RankIcon}}"
                                               Width="46" Height="46" HorizontalAlignment="Center"/>
                                        <TextBlock Text="{Binding Rank}" FontWeight="Bold" FontSize="13"
                                                   HorizontalAlignment="Center" TextAlignment="Center"/>
                                        <TextBlock Text="{Binding Rr}" Foreground="{DynamicResource AccentBrush}"
                                                   FontWeight="Bold" FontSize="12" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <TextBlock Text="CURRENT RANK" Classes="label" HorizontalAlignment="Center"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="26,0" VerticalAlignment="Center" Spacing="6">
                                <TextBlock Text="GAMESENSE REPORT" Classes="muted" FontSize="11" LetterSpacing="2"/>
                                <TextBlock Text="{Binding Headline}" TextWrapping="Wrap" FontSize="15" FontWeight="SemiBold"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2" Spacing="6" HorizontalAlignment="Center" Margin="14,0,10,0">
                                <Border Width="112" Height="112" CornerRadius="56" BorderThickness="7"
                                        BorderBrush="{DynamicResource Accent2Brush}">
                                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding WinRate, StringFormat='{}{0:0}%'}" Classes="accentGlow" FontWeight="Black" FontSize="26" HorizontalAlignment="Center"/>
                                        <TextBlock Text="{Binding WinLoss}" Classes="muted" FontSize="11" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <TextBlock Text="Win Rate" Classes="muted" HorizontalAlignment="Center" FontSize="11"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- tiles -->
                    <UniformGrid Columns="4" Margin="0">
                        <Border Classes="card" Margin="0,0,8,0">
                            <StackPanel><TextBlock Classes="label" Text="K/D RATIO"/><TextBlock Text="{Binding Kd}" Classes="value"/><TextBlock Text="{Binding Adr, StringFormat='{}{0} ADR'}" Classes="muted"/></StackPanel>
                        </Border>
                        <Border Classes="card" Margin="8,0">
                            <StackPanel><TextBlock Classes="label" Text="HEADSHOT %"/><TextBlock Text="{Binding Hs}" Classes="value"/><TextBlock Text="crosshair placement" Classes="muted"/></StackPanel>
                        </Border>
                        <Border Classes="card" Margin="8,0">
                            <StackPanel><TextBlock Classes="label" Text="OPENING KILLS"/><TextBlock Text="{Binding Entries}" Classes="value"/><TextBlock Text="per match" Classes="muted"/></StackPanel>
                        </Border>
                        <Border Classes="card" Margin="8,0,0,0">
                            <StackPanel><TextBlock Classes="label" Text="KAST"/><TextBlock Text="{Binding Kast}" Classes="value"/><TextBlock Text="round impact" Classes="muted"/></StackPanel>
                        </Border>
                    </UniformGrid>

                    <Border Classes="card">
                        <StackPanel>
                            <TextBlock Classes="label" Text="RECENT MATCHES"/>
                            <Grid ColumnDefinitions="80,*,*,70,110,55,60" Margin="4,8,4,4">
                                <TextBlock Classes="label" Text="RESULT"/>
                                <TextBlock Grid.Column="1" Classes="label" Text="AGENT"/>
                                <TextBlock Grid.Column="2" Classes="label" Text="MAP"/>
                                <TextBlock Grid.Column="3" Classes="label" Text="SCORE"/>
                                <TextBlock Grid.Column="4" Classes="label" Text="K / D / A"/>
                                <TextBlock Grid.Column="5" Classes="label" Text="HS%"/>
                                <TextBlock Grid.Column="6" Classes="label" Text="ADR" TextAlignment="Right"/>
                            </Grid>
                            <ItemsControl ItemsSource="{Binding Recent}"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </DataTemplate>

        <!-- ===== Matches ===== -->
        <DataTemplate DataType="vm:MatchesVm">
            <ScrollViewer Padding="30" HorizontalScrollBarVisibility="Disabled">
                <StackPanel Spacing="16" MaxWidth="{Binding $parent[ScrollViewer].Bounds.Width}">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Classes="h1" Text="MATCHES"/>
                        <Button Grid.Column="1" Classes="icon" Content="↻" ToolTip.Tip="Refresh Data" Command="{Binding RefreshCommand}"/>
                    </Grid>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Classes="filter" Content="All" Command="{Binding SetFilterCommand}" CommandParameter="All"
                                BorderBrush="{Binding Filter, Converter={x:Static vm:Conv.EqAccent}, ConverterParameter=All}"/>
                        <Button Classes="filter" Content="Wins" Command="{Binding SetFilterCommand}" CommandParameter="Wins"
                                BorderBrush="{Binding Filter, Converter={x:Static vm:Conv.EqAccent}, ConverterParameter=Wins}"/>
                        <Button Classes="filter" Content="Losses" Command="{Binding SetFilterCommand}" CommandParameter="Losses"
                                BorderBrush="{Binding Filter, Converter={x:Static vm:Conv.EqAccent}, ConverterParameter=Losses}"/>
                    </StackPanel>
                    <Border Classes="card">
                        <StackPanel>
                            <Grid ColumnDefinitions="80,*,*,70,110,55,60" Margin="4,0,4,6">
                                <TextBlock Classes="label" Text="RESULT"/>
                                <TextBlock Grid.Column="1" Classes="label" Text="AGENT"/>
                                <TextBlock Grid.Column="2" Classes="label" Text="MAP"/>
                                <TextBlock Grid.Column="3" Classes="label" Text="SCORE"/>
                                <TextBlock Grid.Column="4" Classes="label" Text="K / D / A"/>
                                <TextBlock Grid.Column="5" Classes="label" Text="HS%"/>
                                <TextBlock Grid.Column="6" Classes="label" Text="ADR" TextAlignment="Right"/>
                            </Grid>
                            <ItemsControl ItemsSource="{Binding Items}"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </DataTemplate>

        <!-- ===== Insights ===== -->
        <DataTemplate DataType="vm:InsightsVm">
            <ScrollViewer Padding="30" HorizontalScrollBarVisibility="Disabled">
                <StackPanel Spacing="16" MaxWidth="{Binding $parent[ScrollViewer].Bounds.Width}">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel>
                            <TextBlock Classes="h1" Text="INSIGHTS"/>
                            <TextBlock Classes="muted" Text="{Binding Summary}" TextWrapping="Wrap" MaxWidth="760"/>
                        </StackPanel>
                        <Button Grid.Column="1" Classes="icon" Content="↻" ToolTip.Tip="Refresh Data" Command="{Binding RefreshCommand}"/>
                    </Grid>
                    <Border Classes="card">
                        <StackPanel>
                            <TextBlock Classes="label" Text="BY MAP"/>
                            <ItemsControl ItemsSource="{Binding Maps}" Margin="0,8,0,0">
                                <ItemsControl.ItemTemplate><DataTemplate x:DataType="vm:StatRow">
                                    <Border Classes="row">
                                        <Grid ColumnDefinitions="*,130,52,84,74">
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                            <ProgressBar Grid.Column="1" Minimum="0" Maximum="100" Value="{Binding WinPct}"
                                                         Height="8" CornerRadius="4" Background="#0A0C18"
                                                         Foreground="{Binding WinBrush}" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="2" Text="{Binding WinLabel}" Foreground="{Binding WinBrush}"
                                                       FontWeight="Bold" FontSize="13" TextAlignment="Right" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="3" Text="{Binding KdLabel}" Classes="muted" TextAlignment="Right" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="4" Text="{Binding GamesLabel}" Classes="muted" FontSize="12" TextAlignment="Right" VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate></ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                    <Border Classes="card">
                        <StackPanel>
                            <TextBlock Classes="label" Text="BY AGENT"/>
                            <ItemsControl ItemsSource="{Binding Agents}" Margin="0,8,0,0">
                                <ItemsControl.ItemTemplate><DataTemplate x:DataType="vm:StatRow">
                                    <Border Classes="row">
                                        <Grid ColumnDefinitions="34,*,130,52,84,74">
                                            <Border Width="28" Height="28" CornerRadius="6" ClipToBounds="True" Background="#FF0A1219" VerticalAlignment="Center">
                                                <Image Source="{Binding Name, Converter={x:Static vm:Conv.AgentIcon}}" Stretch="UniformToFill"/>
                                            </Border>
                                            <TextBlock Grid.Column="1" Text="{Binding Name}" FontWeight="SemiBold" Margin="10,0,0,0" VerticalAlignment="Center"/>
                                            <ProgressBar Grid.Column="2" Minimum="0" Maximum="100" Value="{Binding WinPct}"
                                                         Height="8" CornerRadius="4" Background="#0A0C18"
                                                         Foreground="{Binding WinBrush}" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="3" Text="{Binding WinLabel}" Foreground="{Binding WinBrush}"
                                                       FontWeight="Bold" FontSize="13" TextAlignment="Right" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="4" Text="{Binding KdLabel}" Classes="muted" TextAlignment="Right" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="5" Text="{Binding GamesLabel}" Classes="muted" FontSize="12" TextAlignment="Right" VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate></ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </DataTemplate>

        <!-- ===== Trainer ===== -->
        <DataTemplate DataType="vm:TrainerVm">
            <ScrollViewer Padding="30" HorizontalScrollBarVisibility="Disabled">
                <StackPanel Spacing="16" MaxWidth="{Binding $parent[ScrollViewer].Bounds.Width}">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Classes="h1" Text="SMART TRAINER"/>
                        <Button Grid.Column="1" Classes="icon" Content="↻" ToolTip.Tip="Refresh Data" Command="{Binding RefreshCommand}"/>
                    </Grid>
                    <Border Classes="card" Background="#1A1F3A">
                        <TextBlock Text="{Binding Headline}" TextWrapping="Wrap" FontWeight="SemiBold"/>
                    </Border>
                    <Grid ColumnDefinitions="*,*" >
                        <Border Classes="card" Margin="0,0,8,0">
                            <StackPanel>
                                <TextBlock Classes="label" Text="PERFORMANCE VS BENCHMARKS"/>
                                <ItemsControl ItemsSource="{Binding Bars}" Margin="0,10,0,0">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:BenchRow">
                                            <StackPanel Margin="0,0,0,14">
                                                <Grid ColumnDefinitions="*,Auto">
                                                    <TextBlock Text="{Binding Label}" FontWeight="SemiBold"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding Vals}" Classes="muted" FontSize="12"/>
                                                </Grid>
                                                <ProgressBar Minimum="0" Maximum="100" Value="{Binding FillPct}"
                                                             Height="10" Margin="0,5,0,0" CornerRadius="5"
                                                             Background="#0A0C18" Foreground="{Binding Brush}"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="1" Classes="card" Margin="8,0,0,0">
                            <StackPanel>
                                <TextBlock Classes="label" Text="WHAT'S COSTING YOU GAMES"/>
                                <ItemsControl ItemsSource="{Binding Weaknesses}" Margin="0,10,0,0">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="0,0,0,12">
                                                <TextBlock Text="{Binding Benchmark.Label}" FontWeight="Bold"/>
                                                <TextBlock Text="{Binding Critique}" Classes="muted" TextWrapping="Wrap" FontSize="13"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <TextBlock Classes="label" Text="PRACTICE PLAN" Margin="0,8,0,0"/>
                                <ItemsControl ItemsSource="{Binding Plan}" Margin="0,8,0,0">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="0,0,0,10">
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                                <TextBlock Text="{Binding How}" Classes="muted" TextWrapping="Wrap" FontSize="13"/>
                                                <TextBlock Text="{Binding Where}" Foreground="{DynamicResource Accent2Brush}" FontSize="12"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>
            </ScrollViewer>
        </DataTemplate>

        <!-- ===== Rank ===== -->
        <DataTemplate DataType="vm:RankVm">
            <ScrollViewer Padding="30" HorizontalScrollBarVisibility="Disabled">
                <StackPanel Spacing="16" MaxWidth="{Binding $parent[ScrollViewer].Bounds.Width}">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Classes="h1" Text="RANK TRACKER"/>
                        <Button Grid.Column="1" Classes="icon" Content="↻" ToolTip.Tip="Refresh Data" Command="{Binding RefreshCommand}"/>
                    </Grid>
                    <Grid ColumnDefinitions="Auto,*">
                        <!-- Big current-rank circle, its own panel -->
                        <Border Classes="card accentEdge" Width="300" Margin="0,0,16,0">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
                                <TextBlock Classes="label" Text="CURRENT RANK" HorizontalAlignment="Center"/>
                                <Border Width="172" Height="172" CornerRadius="86" BorderThickness="8"
                                        BorderBrush="{DynamicResource AccentBrush}" Background="#FF0A1219">
                                    <Image Source="{Binding Tier, Converter={x:Static vm:Conv.RankIcon}}"
                                           Width="96" Height="96" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="{Binding Rank}" FontSize="24" FontWeight="Black" HorizontalAlignment="Center"/>
                                <TextBlock Text="{Binding Rr}" Foreground="{DynamicResource AccentBrush}"
                                           FontSize="14" FontWeight="Bold" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <!-- RR trend graph -->
                        <Border Grid.Column="1" Classes="card">
                            <StackPanel>
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Classes="label" Text="RR TREND"/>
                                    <TextBlock Grid.Column="1" Text="{Binding NetRr}" FontWeight="Bold"
                                               Foreground="{DynamicResource Accent2Brush}"/>
                                </Grid>
                                <ctl:Sparkline Points="{Binding RrPoints}" Stroke="{DynamicResource AccentBrush}"
                                               MinHeight="200" Margin="0,14,0,0"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                    <Border Classes="card">
                        <StackPanel>
                            <TextBlock Classes="label" Text="GAME BY GAME"/>
                            <ItemsControl ItemsSource="{Binding History}" Margin="0,8,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="core:RrSnapshot">
                                        <Border Classes="row">
                                            <Grid ColumnDefinitions="*,Auto,80">
                                                <TextBlock Text="{Binding TierName}"/>
                                                <TextBlock Grid.Column="1" Text="{Binding Rr, StringFormat='{}{0} RR'}" Classes="muted"/>
                                                <TextBlock Grid.Column="2" Text="{Binding RrDelta}" TextAlignment="Right" FontWeight="Bold"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </DataTemplate>

        <!-- ===== Live ===== -->
        <DataTemplate DataType="vm:LiveVm">
            <ScrollViewer Padding="30" HorizontalScrollBarVisibility="Disabled">
                <StackPanel Spacing="16" MaxWidth="{Binding $parent[ScrollViewer].Bounds.Width}">
                    <Grid ColumnDefinitions="*,Auto,Auto">
                        <StackPanel><TextBlock Classes="h1" Text="LIVE LOBBY"/><TextBlock Text="{Binding Status}" Classes="muted"/></StackPanel>
                        <Border Grid.Column="1" Classes="chip" VerticalAlignment="Center" Margin="0,0,10,0"
                                IsVisible="{Binding Server, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                            <TextBlock Text="{Binding Server}" Foreground="{DynamicResource Accent2Brush}" FontWeight="SemiBold" FontSize="12"/>
                        </Border>
                        <Button Grid.Column="2" Classes="icon" Content="↻" ToolTip.Tip="Scan Lobby" Command="{Binding ScanCommand}" IsEnabled="{Binding !Busy}"/>
                    </Grid>
                    <UniformGrid Columns="2">
                        <Border Classes="card" Margin="0,0,8,0">
                            <StackPanel>
                                <TextBlock Classes="label" Text="YOUR TEAM"/>
                                <ItemsControl ItemsSource="{Binding Allies}" Margin="0,8,0,0">
                                    <ItemsControl.ItemTemplate><DataTemplate x:DataType="vm:LivePlayer">
                                        <Button Classes="flat" ToolTip.Tip="View career"
                                                Command="{Binding $parent[ItemsControl].((vm:LiveVm)DataContext).ViewCareerCommand}" CommandParameter="{Binding}">
                                            <Border Classes="row"><Grid ColumnDefinitions="*,Auto"><TextBlock Text="{Binding Name}" FontWeight="SemiBold"/><TextBlock Grid.Column="1" Text="{Binding Rank}" Classes="muted"/></Grid></Border>
                                        </Button>
                                    </DataTemplate></ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="1" Classes="card" Margin="8,0,0,0">
                            <StackPanel>
                                <TextBlock Classes="label" Text="ENEMY TEAM"/>
                                <ItemsControl ItemsSource="{Binding Enemies}" Margin="0,8,0,0">
                                    <ItemsControl.ItemTemplate><DataTemplate x:DataType="vm:LivePlayer">
                                        <Button Classes="flat" ToolTip.Tip="View career"
                                                Command="{Binding $parent[ItemsControl].((vm:LiveVm)DataContext).ViewCareerCommand}" CommandParameter="{Binding}">
                                            <Border Classes="row"><Grid ColumnDefinitions="*,Auto"><TextBlock Text="{Binding Name}" FontWeight="SemiBold"/><TextBlock Grid.Column="1" Text="{Binding Rank}" Classes="muted"/></Grid></Border>
                                        </Button>
                                    </DataTemplate></ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <ContentControl Content="{Binding Career}"/>
                </StackPanel>
            </ScrollViewer>
        </DataTemplate>

        <!-- ===== Agents ===== -->
        <DataTemplate DataType="vm:AgentsVm">
            <ScrollViewer Padding="30" HorizontalScrollBarVisibility="Disabled">
                <StackPanel Spacing="16" MaxWidth="{Binding $parent[ScrollViewer].Bounds.Width}">
                    <StackPanel><TextBlock Classes="h1" Text="AGENT PICKER"/><TextBlock Text="{Binding Status}" Classes="muted"/></StackPanel>
                    <Border Classes="card" Background="#1A1F3A" IsVisible="{Binding SelectedName, Converter={x:Static ObjectConverters.IsNotNull}}">
                        <TextBlock><Run Text="Pre-selected: "/><Run Text="{Binding SelectedName}" FontWeight="Bold"/><Run Text=" — auto-locks once agent select loads"/></TextBlock>
                    </Border>
                    <ItemsControl ItemsSource="{Binding Agents}">
                        <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:AgentCard">
                                <Button Width="150" Height="92" Margin="6" Padding="0" Background="Transparent"
                                        Command="{Binding $parent[ItemsControl].((vm:AgentsVm)DataContext).PickCommand}"
                                        CommandParameter="{Binding}">
                                    <Border CornerRadius="10" Padding="10" BorderThickness="2"
                                            Background="{StaticResource PanelGrad}"
                                            BorderBrush="{Binding Selected, Converter={x:Static vm:Conv.SelBorder}}">
                                        <Grid ColumnDefinitions="44,*">
                                            <Border Width="40" Height="40" CornerRadius="8" ClipToBounds="True" Background="#FF0A1219">
                                                <Image Source="{Binding Name, Converter={x:Static vm:Conv.AgentIcon}}" Stretch="UniformToFill"/>
                                            </Border>
                                            <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Role}" FontSize="10" Foreground="{DynamicResource AccentBrush}" FontWeight="Bold"/>
                                                <TextBlock Text="{Binding Name}" FontSize="15" FontWeight="Bold"/>
                                                <TextBlock Text="{Binding Stats}" Classes="muted" FontSize="11"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>
        </DataTemplate>

        <!-- ===== Settings ===== -->
        <DataTemplate DataType="vm:SettingsVm">
            <ScrollViewer Padding="30" HorizontalScrollBarVisibility="Disabled">
                <StackPanel Spacing="16" MaxWidth="620" HorizontalAlignment="Left">
                    <TextBlock Classes="h1" Text="SETTINGS"/>
                    <Border Classes="card">
                        <StackPanel Spacing="8">
                            <TextBlock Classes="label" Text="HENRIKDEV API KEY"/>
                            <TextBlock Classes="muted" TextWrapping="Wrap" Text="With a key: any account, game not needed. Without: reads your running Riot client."/>
                            <TextBox Watermark="paste key" Text="{Binding ApiKey}" PasswordChar="•"/>
                            <Button Classes="primary" Content="Save key" HorizontalAlignment="Left" Command="{Binding SaveKeyCommand}"/>
                            <TextBlock Text="{Binding Status}" Classes="muted" TextWrapping="Wrap"
                                       IsVisible="{Binding Status, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                        </StackPanel>
                    </Border>
                    <Border Classes="card">
                        <StackPanel Spacing="8">
                            <TextBlock Classes="label" Text="TRACKED RIOT ACCOUNT"/>
                            <Grid ColumnDefinitions="120,*,120" >
                                <ComboBox ItemsSource="{Binding Regions}" SelectedItem="{Binding Region}" Margin="0,0,8,0"/>
                                <TextBox Grid.Column="1" Watermark="Riot name" Text="{Binding Name}" Margin="0,0,8,0"/>
                                <TextBox Grid.Column="2" Watermark="Tag" Text="{Binding Tag}"/>
                            </Grid>
                            <Button Classes="primary" Content="Save &amp; load" HorizontalAlignment="Left" Command="{Binding SaveAccountCommand}"/>
                        </StackPanel>
                    </Border>
                    <Border Classes="card accentEdge">
                        <StackPanel Spacing="10">
                            <TextBlock Classes="label" Text="THEME"/>
                            <Grid ColumnDefinitions="*,Auto">
                                <ComboBox ItemsSource="{Binding Themes}" SelectedItem="{Binding Theme}"
                                          IsEnabled="{Binding !UseRankTheme}" HorizontalAlignment="Stretch"/>
                                <CheckBox Grid.Column="1" Content="Use Rank Theme" IsChecked="{Binding UseRankTheme}" Margin="12,0,0,0"/>
                            </Grid>
                            <TextBlock Classes="muted" FontSize="12"
                                       Text="Applies instantly. Rank theme recolors the app by your current rank."/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </DataTemplate>

        <!-- ===== Scoreboard row (click to view that player's career) ===== -->
        <DataTemplate DataType="vm:ScoreRow">
            <Button Classes="flat" ToolTip.Tip="View career"
                    Command="{Binding $parent[ItemsControl].((vm:MatchDetailVm)DataContext).ViewPlayerCommand}"
                    CommandParameter="{Binding}">
                <Border Classes="row" Background="{Binding IsSelf, Converter={x:Static vm:Conv.SelfBg}}" CornerRadius="6">
                    <Grid ColumnDefinitions="*,96,100,46,50">
                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                        <TextBlock Grid.Column="1" Text="{Binding Agent}" Classes="muted"/>
                        <TextBlock Grid.Column="2" Text="{Binding Kda}"/>
                        <TextBlock Grid.Column="3" Text="{Binding Hs, StringFormat='{}{0}%'}" Classes="muted"/>
                        <TextBlock Grid.Column="4" Text="{Binding Adr}" Classes="muted" TextAlignment="Right"/>
                    </Grid>
                </Border>
            </Button>
        </DataTemplate>

        <!-- ===== Match detail ===== -->
        <DataTemplate DataType="vm:MatchDetailVm">
            <ScrollViewer Padding="30" HorizontalScrollBarVisibility="Disabled">
                <StackPanel Spacing="16" MaxWidth="{Binding $parent[ScrollViewer].Bounds.Width}">
                    <StackPanel Orientation="Horizontal" Spacing="14">
                        <Button Classes="icon" Content="‹" ToolTip.Tip="Back"
                                Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).BackCommand}"/>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Classes="h1" Text="{Binding Header}"/>
                            <TextBlock Text="{Binding Sub}" Classes="muted"/>
                        </StackPanel>
                    </StackPanel>
                    <TextBlock Text="{Binding Error}" Foreground="{StaticResource LossBrush}"
                               IsVisible="{Binding Error, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                    <Border Classes="card accentEdge">
                        <TextBlock Text="{Binding YourLine}" FontWeight="Bold" FontSize="15"/>
                    </Border>
                    <Border Classes="card" IsVisible="{Binding Economy.Count}">
                        <StackPanel>
                            <TextBlock Classes="label" Text="YOUR BUY PATTERN"/>
                            <ItemsControl ItemsSource="{Binding Economy}" Margin="0,8,0,0">
                                <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="core:RoundEconomy">
                                        <Border Width="26" Height="26" CornerRadius="6" Margin="2"
                                                Background="{Binding BuyType, Converter={x:Static vm:Conv.BuyBrush}}"
                                                ToolTip.Tip="{Binding BuyType}">
                                            <TextBlock Text="{Binding RoundNumber}" FontSize="11" FontWeight="Bold"
                                                       Foreground="#0A1219" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                    <Grid ColumnDefinitions="*,*">
                        <Border Classes="card" Margin="0,0,8,0">
                            <StackPanel><TextBlock Classes="label" Text="RED TEAM"/><ItemsControl ItemsSource="{Binding Red}" Margin="0,8,0,0"/></StackPanel>
                        </Border>
                        <Border Grid.Column="1" Classes="card" Margin="8,0,0,0">
                            <StackPanel><TextBlock Classes="label" Text="BLUE TEAM"/><ItemsControl ItemsSource="{Binding Blue}" Margin="0,8,0,0"/></StackPanel>
                        </Border>
                    </Grid>
                    <ContentControl Content="{Binding Career}"/>
                </StackPanel>
            </ScrollViewer>
        </DataTemplate>

        <!-- ===== Career popover (shared: Live lobby + Match detail) ===== -->
        <DataTemplate DataType="vm:CareerVm">
            <Border Classes="card accentEdge" IsVisible="{Binding Open}" Margin="0,4,0,0">
                <StackPanel Spacing="10">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock FontWeight="Bold" FontSize="15"><Run Text="Career · "/><Run Text="{Binding Name}"/></TextBlock>
                        <Button Grid.Column="1" Classes="icon" Content="✕" ToolTip.Tip="Close" Command="{Binding CloseCommand}"/>
                    </Grid>
                    <TextBlock Text="Loading…" Classes="muted" IsVisible="{Binding Loading}"/>
                    <TextBlock Classes="muted" TextWrapping="Wrap" IsVisible="{Binding Empty}"
                               Text="No career data — needs Valorant / the Riot client running."/>
                    <StackPanel IsVisible="{Binding Data, Converter={x:Static ObjectConverters.IsNotNull}}">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <Border Classes="chip"><TextBlock Text="{Binding Data.Rank.Name}" Foreground="{StaticResource GoldBrush}" FontWeight="SemiBold" FontSize="12"/></Border>
                            <Border Classes="chip"><TextBlock Text="{Binding Data.WinRate, StringFormat='{}{0:0}% WR'}" FontSize="12"/></Border>
                            <Border Classes="chip"><TextBlock Text="{Binding Data.AvgKd, StringFormat='{}{0:0.00} K/D'}" FontSize="12"/></Border>
                        </StackPanel>
                        <ItemsControl ItemsSource="{Binding Data.Recent}" Margin="0,10,0,0">
                            <ItemsControl.ItemTemplate><DataTemplate x:DataType="core:MatchSummary">
                                <Border Classes="row">
                                    <Grid ColumnDefinitions="60,*,Auto,Auto">
                                        <TextBlock Text="{Binding ResultLabel}" FontWeight="Bold" FontSize="12"
                                                   Foreground="{Binding Result, Converter={x:Static vm:Conv.ResultBrush}}"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Agent}"/>
                                        <TextBlock Grid.Column="2" Text="{Binding ScoreLabel}" Classes="muted" Margin="0,0,16,0"/>
                                        <TextBlock Grid.Column="3" Text="{Binding KdaLabel}" Classes="muted"/>
                                    </Grid>
                                </Border>
                            </DataTemplate></ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </StackPanel>
            </Border>
        </DataTemplate>
    </Window.DataTemplates>

    <Grid ColumnDefinitions="204,*">
        <!-- Sidebar -->
        <Border Background="{StaticResource Bg1}" BorderBrush="{StaticResource LineBrush}" BorderThickness="0,0,1,0">
            <DockPanel Margin="12,22">
                <Image DockPanel.Dock="Top" Source="avares://SenseSation/Assets/logo/SenseSationLogo.png"
                       Stretch="Uniform" HorizontalAlignment="Center" MaxHeight="62" Margin="0,0,0,30"/>

                <TextBlock DockPanel.Dock="Bottom" Text="{Binding Version}" Classes="label"
                           Foreground="{StaticResource FaintBrush}" Margin="6,18,0,0"/>

                <ItemsControl ItemsSource="{Binding Pages}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:PageVm">
                            <Button Classes="nav" Classes.active="{Binding IsActive}" Margin="0,0,0,6"
                                    Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).NavigateCommand}"
                                    CommandParameter="{Binding}">
                                <StackPanel Orientation="Horizontal" Spacing="11">
                                    <Panel Width="22" Height="22" VerticalAlignment="Center">
                                        <Image Source="{Binding IconAsset, Converter={x:Static vm:Conv.AssetBitmap}}"
                                               IsVisible="{Binding IconAsset, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                        <TextBlock Text="{Binding Glyph}" FontSize="15" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   IsVisible="{Binding IconAsset, Converter={x:Static StringConverters.IsNullOrEmpty}}"/>
                                    </Panel>
                                    <TextBlock Text="{Binding Title}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </DockPanel>
        </Border>

        <!-- Main -->
        <DockPanel Grid.Column="1">
            <Border DockPanel.Dock="Top" Background="{StaticResource Bg1}" BorderBrush="{StaticResource LineBrush}" BorderThickness="0,0,0,1" Padding="30,14">
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Orientation="Horizontal" Spacing="14" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Account}" FontWeight="Bold" FontSize="15"/>
                        <Border Classes="chip" IsVisible="{Binding RankText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                            <TextBlock Text="{Binding RankText}" Foreground="{StaticResource GoldBrush}" FontWeight="SemiBold" FontSize="12"/>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <TransitioningContentControl Content="{Binding Current}">
                <TransitioningContentControl.PageTransition>
                    <CrossFade Duration="0:0:0.22"/>
                </TransitioningContentControl.PageTransition>
            </TransitioningContentControl>
        </DockPanel>
    </Grid>
</Window>
