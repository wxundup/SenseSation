@{
    var b = Benchmark;
    // Scale: 0 .. max(Radiant, Good, Your) with a little headroom.
    double max = Math.Max(Math.Max(b.Radiant, b.Good), Your) * 1.1;
    if (max <= 0) max = 1;
    double fillPct = b.HigherIsBetter ? Your / max * 100 : Your / max * 100;
    double goodPct = b.Good / max * 100;
    fillPct = Math.Clamp(fillPct, 2, 100);
    goodPct = Math.Clamp(goodPct, 0, 100);
}
<div class="bench @SevClass">
    <div class="hdr">
        <span class="label">@b.Label</span>
        <span class="vals mono">
            <strong>@Fmt(Your)</strong>
            <span class="muted"> / target @Fmt(b.Good) · radiant @Fmt(b.Radiant)</span>
        </span>
    </div>
    <div class="track">
        <div class="fill" style="width:@fillPct.ToString("0.#", Inv)%"></div>
        <div class="target" style="left:@goodPct.ToString("0.#", Inv)%" title="Target @Fmt(b.Good)"></div>
    </div>
</div>

@code {
    [Parameter, EditorRequired] public Benchmark Benchmark { get; set; } = default!;
    [Parameter] public double Your { get; set; }
    /// <summary>One of: ok, minor, notable, major.</summary>
    [Parameter] public string Severity { get; set; } = "ok";

    private static readonly System.Globalization.CultureInfo Inv = System.Globalization.CultureInfo.InvariantCulture;
    private string SevClass => $"sev-{Severity}";
    private string Fmt(double v) => Benchmark.Unit == "%" ? $"{v.ToString("0.#", Inv)}%" : v.ToString("0.##", Inv);
}
