@page "/"
@inject AppData App
@inject NavigationManager Nav

<PageTitle>SenseSation · Dashboard</PageTitle>

<StateBanner />

@if (App.HasData)
{
    var m = App.Metrics;
    var rank = App.Rank ?? Rank.Unranked;

    <div class="card hero" style="margin-bottom:16px">
        <div class="rankwrap">
            <Ring Percent="rank.Rr" Color="@RankColor(rank)" Size="128"
                  Top="@(rank.Rr > 0 ? rank.Rr.ToString() : "—")" Bottom="@(rank.Rr > 0 ? "RR" : "")" />
            <div class="rankname">@rank.Name</div>
        </div>

        <div>
            <div class="hgreet">GameSense Report</div>
            <div class="hname">@HeroName</div>
            <div style="display:flex;gap:8px;flex-wrap:wrap;margin-bottom:12px">
                <span class="chip">@m.MatchesAnalyzed matches</span>
                <span class="chip @(m.WinRate >= 50 ? "" : "")">@m.Wins W · @m.Losses L</span>
                <span class="chip">@(string.IsNullOrEmpty(m.TopAgent) ? "—" : m.TopAgent) main</span>
            </div>
            <p class="muted" style="max-width:62ch;margin:0">@App.Report?.Headline</p>
            <button class="btn primary" style="margin-top:14px" @onclick="Refresh" disabled="@App.IsLoading">
                <Icon Name="refresh" Size="16" /> @(App.IsLoading ? "Loading…" : "Refresh")
            </button>
        </div>

        <div class="rankwrap">
            <Ring Percent="m.WinRate" Color="@(m.WinRate >= 50 ? "var(--win)" : "var(--loss)")" Size="128"
                  Top="@($"{m.WinRate:0}%")" Bottom="Win Rate" />
            <div class="rankname">@m.Wins–@m.Losses</div>
        </div>
    </div>

    <div class="grid cols-4">
        <Tile Icon="crosshair" Label="K/D Ratio" Value="@m.Kd.ToString("0.00")"
              Sub="@($"{m.Adr:0} ADR")" Accent="@(m.Kd >= 1 ? "var(--win)" : "var(--loss)")" />
        <Tile Icon="target" Label="Headshot %" Value="@($"{m.HeadshotPct:0.#}%")" Sub="crosshair placement" />
        <Tile Icon="flame" Label="Opening Kills" Value="@m.FirstKillsPerMatch.ToString("0.#")" Sub="per match · entry impact" />
        <Tile Icon="bolt" Label="KAST" Value="@($"{m.Kast:0}%")" Sub="round contribution" />
    </div>

    <div class="grid cols-2" style="margin-top:16px">
        <div class="card">
            <h3>RR Trend</h3>
            <RrChart Points="App.RrHistory" />
        </div>
        <div class="card">
            <h3>Coach's Verdict</h3>
            <p style="font-weight:600;margin:8px 0 14px">@App.Report?.Headline</p>
            @if (App.Report is { Weaknesses.Count: > 0 })
            {
                @foreach (var w in App.Report.Weaknesses.Take(3))
                {
                    <div style="display:flex;gap:10px;align-items:flex-start;margin-bottom:9px">
                        <span class="chip @SevName(w.Severity)" style="flex:0 0 auto">@w.Benchmark.Label</span>
                        <span class="muted" style="font-size:.86rem">@w.Critique</span>
                    </div>
                }
            }
            <a class="btn" href="trainer" style="margin-top:6px"><Icon Name="trainer" Size="16" /> Open Smart Trainer</a>
        </div>
    </div>

    <div class="card" style="margin-top:16px">
        <div style="display:flex;justify-content:space-between;align-items:center">
            <h3>Recent Matches</h3>
            <a href="matches">View all →</a>
        </div>
        <table>
            <thead><tr><th>Result</th><th>Agent</th><th>Map</th><th>Score</th><th>K / D / A</th><th>HS%</th><th>ADR</th></tr></thead>
            <tbody>
                @foreach (var match in App.Matches.Take(6))
                {
                    <tr class="row-link" @onclick="@(() => Nav.NavigateTo($"match/{match.MatchId}"))">
                        <td class="@ResultClass(match.Result)">@match.Result.ToString().ToUpper()</td>
                        <td>@match.Agent</td><td>@match.Map</td>
                        <td class="mono">@match.ScoreLabel</td>
                        <td class="mono">@match.You.Kills / @match.You.Deaths / @match.You.Assists</td>
                        <td class="mono">@match.You.HeadshotPct%</td>
                        <td class="mono">@match.You.DamagePerRound</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
else if (App.IsConfigured && !App.IsLoading)
{
    <div class="empty">
        <div class="big"><Icon Name="dashboard" Size="52" /></div>
        <p>No matches loaded yet.</p>
        <button class="btn primary" @onclick="Refresh"><Icon Name="refresh" Size="16" /> Load my stats</button>
    </div>
}

@code {
    protected override async Task OnInitializedAsync()
    {
        if (App.IsConfigured && !App.HasData && !App.IsLoading)
            await App.LoadAsync();
    }

    private async Task Refresh() => await App.LoadAsync();

    private string HeroName => App.SourceNeedsRiotId && App.IsConfigured ? App.Account.Name : "Operator";

    private static string ResultClass(MatchResult r) => r switch
    {
        MatchResult.Win => "tag-win", MatchResult.Loss => "tag-loss", _ => "tag-draw"
    };
    private static string SevName(Severity s) => s switch
    {
        Severity.Major => "major", Severity.Notable => "notable", _ => "minor"
    };
    private static string RankColor(Rank r) => r.Division switch
    {
        "Iron" => "#6b6b6b", "Bronze" => "#a9743b", "Silver" => "#c8cdd2", "Gold" => "#f5c451",
        "Platinum" => "#4fb6c4", "Diamond" => "#b57edc", "Ascendant" => "#1f9d55",
        "Immortal" => "#b43b54", "Radiant" => "#fff7c0", _ => "var(--teal)"
    };
}
