<span class="rankpill" title="@Rank.Name">
    <span class="dot" style="background:@Color"></span>
    @Rank.Name@(ShowRr && Rank.Rr > 0 ? $" · {Rank.Rr} RR" : "")
</span>

@code {
    [Parameter] public Rank Rank { get; set; } = Rank.Unranked;
    [Parameter] public bool ShowRr { get; set; } = true;

    private string Color => Rank.Division switch
    {
        "Iron" => "#6b6b6b",
        "Bronze" => "#a9743b",
        "Silver" => "#c8cdd2",
        "Gold" => "#f5c451",
        "Platinum" => "#4fb6c4",
        "Diamond" => "#b57edc",
        "Ascendant" => "#1f9d55",
        "Immortal" => "#b43b54",
        "Radiant" => "#fff7c0",
        _ => "#555c63"
    };
}
