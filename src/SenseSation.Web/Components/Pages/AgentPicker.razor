@page "/agents"
@inject ILiveClient Client
@inject AppData App
@implements IDisposable

<PageTitle>SenseSation · Agent Picker</PageTitle>

<div class="page-head">
    <div>
        <h1>Agent Picker</h1>
        <div class="sub">
            @if (_pre is { IsAgentSelect: true })
            {
                <span>Character select · @_pre.Map</span>
            }
            else if (_pre is not null)
            {
                <span>Pre-game · @_pre.Phase · @_pre.Map</span>
            }
            else if (_scanning)
            {
                <span>Waiting for agent select…</span>
            }
            else
            {
                <span>No pre-game lobby — join a match first</span>
            }
        </div>
    </div>
    <button class="btn primary" @onclick="ScanNow" disabled="@_scanning">↻</button>
</div>

@if (_selected is not null)
{
    <div class="banner info" style="justify-content:space-between">
        <span style="display:flex;align-items:center;gap:10px">
            <img src="/agents/@(_selected).png" alt="@_selected" style="width:24px;height:24px;border-radius:4px" />
            Pre-selected: <strong>@_selected</strong>
            @(_pre is { IsAgentSelect: true } ? "on " + _pre.Map + " — locking in" : "— auto-locks when agent select loads")
        </span>
        <button class="btn" style="background:var(--teal);color:#06231f" @onclick="ForceLock" disabled="@_busy">
            🔒 Lock @_selected now
        </button>
    </div>
}

@if (_error is not null)
{
    <div class="banner warn">@_error</div>
}

@if (_pre?.Allies is { Count: > 0 })
{
    <div style="display:flex;gap:24px;flex-wrap:wrap;margin-bottom:18px;font-size:.85rem">
        <span class="muted" style="text-transform:uppercase;letter-spacing:1px;font-weight:700">Lobby:</span>
        @foreach (var a in _pre.Allies)
        {
            var ag = a.CharacterId is not null ? CharacterTable.Name(a.CharacterId) : "";
            <span class="chip @(a.Locked ? "major" : "minor")" title="@a.Puuid">
                @if (!string.IsNullOrEmpty(ag))
                {
                    <img src="/agents/@(ag).png" alt="@ag" style="width:16px;height:16px;border-radius:3px;vertical-align:middle;margin-right:3px" />
                }
                @(string.IsNullOrEmpty(ag) ? "—" : ag)@(a.Locked ? " 🔒" : "")
            </span>
        }
    </div>
}

@{
    var grouped = (from ag in AgentInfo.All
                   let st = GetStats(ag.Name)
                   orderby st.matches descending, st.winRate descending
                   select (info: ag, stats: st)).ToList();
}
<div class="grid cols-3" style="gap:12px">
    @foreach (var (info, st) in grouped)
    {
        bool lockedByTeammate = _pre?.Allies.Any(a => a.Locked && CharacterTable.Name(a.CharacterId ?? "") == info.Name) ?? false;
        <div class="acard @(_selected == info.Name ? "sel" : "") @(lockedByTeammate ? "taken" : "")"
             style="@AgentInfo.BodyStyle(info.Name, lockedByTeammate)"
             @onclick="@(() => PreSelect(info.Name))">
            <div style="display:flex;align-items:center;gap:8px">
                <img src="/agents/@(info.Name).png" alt="@info.Name"
                     style="width:36px;height:36px;border-radius:6px" />
                <div style="min-width:0">
                    <div class="role" style="color:@info.Color">@info.Role</div>
                    <div class="aname">@info.Name</div>
                </div>
            </div>
            @if (st.matches > 0)
            {
                <div class="astats">
                    <span class="chip @(st.winRate >= 50 ? "" : "major")">@st.winRate% @st.wins-@st.losses</span>
                    <span class="chip">@st.kd K/D</span>
                </div>
                <div class="atar" style="margin-top:6px">
                    <div class="track" style="height:6px">
                        <div class="fill sev-ok" style="width:@((int)st.winRate)%"></div>
                    </div>
                </div>
                <div class="muted" style="font-size:.68rem;margin-top:4px">@st.matches game@(st.matches == 1 ? "" : "s")</div>
            }
        </div>
    }
</div>

@code {
    private PreGameLobby? _pre;
    private string? _selected;
    private string? _error;
    private bool _scanning;
    private bool _busy;             // a select/lock call is in flight
    private string? _seenMatchId;  // match we've started the select sequence for
    private DateTime? _selectSeenAt; // when we first saw character_select for this match
    private bool _disposed;
    private Timer? _timer;

    private const int PreHoverMs = 1000; // wait after detecting agent select so the menu renders
    private const int SettleMs = 150;    // tiny gap between hover and lock

    protected override void OnInitialized()
    {
        // Poll once a second so we react quickly to entering character select.
        _timer = new Timer(async _ => await Poll(), null, TimeSpan.Zero, TimeSpan.FromSeconds(1));
    }

    private async Task Poll()
    {
        if (_scanning) return;
        _scanning = true;
        try
        {
            if (!Client.IsConnected) await Client.ConnectAsync();
            _pre = await Client.GetPreGameAsync();
            // Surface real failures (incl. "Pre-game read failed: ..."), hide idle/lobby states.
            _error = RealError(Client.LastError);

            await DriveSelectionAsync();
        }
        catch { }
        finally
        {
            _scanning = false;
            try { if (!_disposed) await InvokeAsync(StateHasChanged); }
            catch (ObjectDisposedException) { /* component torn down mid-poll */ }
        }
    }

    /// <summary>
    /// Reads the live pre-game state and only locks once the game CONFIRMS our agent is
    /// hovered (which can only happen once the menu is fully loaded), then after a settle delay.
    /// </summary>
    private async Task DriveSelectionAsync()
    {
        if (_busy) return;

        // Not in agent select — reset so we re-arm for the next match.
        if (_pre is not { IsAgentSelect: true })
        {
            _seenMatchId = null;
            _selectSeenAt = null;
            return;
        }
        if (_selected is null) return;

        // First time we see character select for this match — start the grace timer.
        // The API flips to character_select_active before the client menu finishes loading,
        // so wait ~1s before touching anything to avoid hovering/locking during the load.
        if (_seenMatchId != _pre.MatchId)
        {
            _seenMatchId = _pre.MatchId;
            _selectSeenAt = DateTime.UtcNow;
            return;
        }
        if (_selectSeenAt is { } t && (DateTime.UtcNow - t).TotalMilliseconds < PreHoverMs)
            return; // let the menu render

        var self = _pre.Allies.FirstOrDefault(a => a.Puuid == Client.SelfPuuid);
        if (string.IsNullOrEmpty(self.Puuid)) return; // can't identify self yet — don't guess
        if (self.Locked) return;                      // already locked (state string, GUID-independent)

        // Menu is loaded (past the grace) → hover then lock with a tiny gap. Retries each poll
        // until the game reports us locked. Uses the lock STATE, not the agent/GUID table, so it
        // works for every agent regardless of icon-table accuracy.
        await RunAsync(async () =>
        {
            await Client.SelectAgentAsync(_selected);
            await Task.Delay(SettleMs);
            await Client.LockAgentAsync(_selected);
        });
    }

    private async Task RunAsync(Func<Task> op)
    {
        _busy = true;
        try { await op(); await InvokeAsync(() => { _error = null; StateHasChanged(); }); }
        catch (Exception ex) { await InvokeAsync(() => { _error = ex.Message; StateHasChanged(); }); }
        finally { _busy = false; }
    }

    private async Task ScanNow() => await Poll();

    /// <summary>Manual fallback: hover + lock the selected agent now, even if auto-detect missed.</summary>
    private async Task ForceLock()
    {
        if (_selected is null) return;
        await RunAsync(async () =>
        {
            await Client.SelectAgentAsync(_selected);
            await Task.Delay(SettleMs);
            await Client.LockAgentAsync(_selected);
        });
    }

    private static string? RealError(string? e)
    {
        if (string.IsNullOrWhiteSpace(e)) return null;
        var l = e.ToLowerInvariant();
        return (l.Contains("failed") || l.Contains("not running") || l.Contains("lockfile")
                || l.Contains("administrator") || l.Contains("could not") || l.Contains("session"))
            ? e : null;
    }

    private Task PreSelect(string agent)
    {
        _selected = agent;
        _error = null;
        // The poll drives hover + confirmed-lock uniformly (also when buffered before the match).
        return Task.CompletedTask;
    }

    private (int matches, int wins, int losses, double winRate, double kd) GetStats(string agent)
    {
        var list = App.Matches.Where(m => m.Agent.Equals(agent, StringComparison.OrdinalIgnoreCase)).ToList();
        int n = list.Count;
        if (n == 0) return (0, 0, 0, 0, 0);
        int w = list.Count(m => m.Result == MatchResult.Win);
        int l = list.Count(m => m.Result == MatchResult.Loss);
        double wr = Math.Round(100.0 * w / n, 0);
        double kd = Math.Round(list.Average(m => m.You.Kd), 2);
        return (n, w, l, wr, kd);
    }

    public void Dispose() { _disposed = true; _timer?.Dispose(); }
}
