@if (Points.Count < 2)
{
    <div class="empty"><div class="big">▲</div>Not enough ranked games yet to chart RR.</div>
}
else
{
    <svg viewBox="0 0 @W @H" preserveAspectRatio="none" style="width:100%;height:200px;display:block">
        <defs>
            <linearGradient id="rrfill" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0%" stop-color="#00e0c6" stop-opacity="0.35" />
                <stop offset="100%" stop-color="#00e0c6" stop-opacity="0" />
            </linearGradient>
        </defs>
        <polygon points="@AreaPoints" fill="url(#rrfill)" />
        <polyline points="@LinePoints" fill="none" stroke="#00e0c6" stroke-width="2.5"
                  stroke-linejoin="round" stroke-linecap="round" />
        @for (int i = 0; i < _xy.Count; i++)
        {
            var p = _xy[i];
            <circle cx="@F(p.x)" cy="@F(p.y)" r="@(i == _xy.Count - 1 ? 4.5 : 2.5)"
                    fill="@(i == _xy.Count - 1 ? "#fff" : "#00e0c6")" />
        }
    </svg>
}

@code {
    [Parameter] public IReadOnlyList<RrSnapshot> Points { get; set; } = [];

    private const double W = 640, H = 200, Pad = 14;
    private List<(double x, double y)> _xy = [];

    private static readonly System.Globalization.CultureInfo Inv = System.Globalization.CultureInfo.InvariantCulture;
    private static string F(double v) => v.ToString("0.#", Inv);

    protected override void OnParametersSet()
    {
        _xy = [];
        if (Points.Count < 2) return;

        var vals = Points.Select(p => (double)p.LadderPoints).ToList();
        double min = vals.Min(), max = vals.Max();
        if (Math.Abs(max - min) < 1) { max = min + 1; }

        for (int i = 0; i < Points.Count; i++)
        {
            double x = Pad + (W - 2 * Pad) * i / (Points.Count - 1);
            double y = H - Pad - (H - 2 * Pad) * (vals[i] - min) / (max - min);
            _xy.Add((x, y));
        }
    }

    private string LinePoints => string.Join(" ", _xy.Select(p => $"{F(p.x)},{F(p.y)}"));
    private string AreaPoints =>
        _xy.Count == 0 ? "" :
        $"{F(_xy[0].x)},{F(H - Pad)} " + LinePoints + $" {F(_xy[^1].x)},{F(H - Pad)}";
}
