<table>
    <thead><tr><th>Player</th><th>Rank</th><th></th></tr></thead>
    <tbody>
        @foreach (var p in Players.OrderByDescending(p => p.Rank.Tier))
        {
            <tr class="@(p.IsSelf ? "self-row" : "") @(OnSelect.HasDelegate ? "row-link" : "")"
                @onclick="@(() => OnSelect.HasDelegate ? OnSelect.InvokeAsync(p) : Task.CompletedTask)">
                <td><strong>@(string.IsNullOrEmpty(p.Name) ? "Player" : p.DisplayName)</strong>@(p.IsSelf ? " (you)" : "")</td>
                <td><RankPill Rank="p.Rank" ShowRr="false" /></td>
                <td class="faint" style="text-align:right">@(OnSelect.HasDelegate ? "career →" : "")</td>
            </tr>
        }
    </tbody>
</table>

@code {
    [Parameter] public IReadOnlyList<PlayerSummary> Players { get; set; } = [];
    [Parameter] public EventCallback<PlayerSummary> OnSelect { get; set; }
}
