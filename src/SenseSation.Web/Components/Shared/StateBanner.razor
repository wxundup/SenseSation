@inject AppData App

@if (App.IsLoading)
{
    <div class="banner info"><span class="spinner"></span> &nbsp;Loading from HenrikDev…</div>
}
else if (!App.IsConfigured)
{
    <div class="banner warn">
        No Riot ID set. <a href="settings">Open Settings</a> to enter your region, name and tag.
    </div>
}
else if (!string.IsNullOrEmpty(App.Error))
{
    <div class="banner @(App.ServedFromCache ? "warn" : "err")">@App.Error</div>
}
