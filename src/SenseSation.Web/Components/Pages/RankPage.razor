@page "/rank"
@inject AppData App

<PageTitle>SenseSation · Rank</PageTitle>

<div class="page-head">
    <div><h1>Rank Tracker</h1><div class="sub">Competitive RR over time</div></div>
    @if (App.IsConfigured)
    {
        <button class="btn primary" @onclick="Refresh" disabled="@App.IsLoading">↻ Refresh</button>
    }
</div>

<StateBanner />

@if (App.IsConfigured)
{
    <div class="grid cols-3">
        <div class="card stat">
            <h3>Current Rank</h3>
            <div style="margin-top:8px"><RankPill Rank="App.Rank ?? Rank.Unranked" /></div>
        </div>
        <StatCard Title="Recent Net RR" Value="@NetRr()" Accent="@(NetRrValue() >= 0 ? "var(--win)" : "var(--loss)")"
                  Sub="@($"over last {App.RrHistory.Count} ranked games")" />
        <StatCard Title="Best / Worst Swing" Value="@Swing()" SubClass="muted" Sub="single game" />
    </div>

    <div class="card" style="margin-top:16px">
        <h3>RR History</h3>
        <RrChart Points="App.RrHistory" />
    </div>

    @if (App.RrHistory.Count > 0)
    {
        <div class="card" style="margin-top:16px">
            <h3>Game-by-Game</h3>
            <table>
                <thead><tr><th>Date</th><th>Rank</th><th>RR</th><th>Change</th></tr></thead>
                <tbody>
                    @foreach (var s in App.RrHistory.Reverse().Take(25))
                    {
                        <tr>
                            <td class="muted mono">@s.At.LocalDateTime.ToString("MMM d, HH:mm")</td>
                            <td>@s.TierName</td>
                            <td class="mono">@s.Rr</td>
                            <td class="mono @(s.RrDelta >= 0 ? "up" : "down")">@(s.RrDelta >= 0 ? "+" : "")@s.RrDelta</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
}

@code {
    protected override async Task OnInitializedAsync()
    {
        if (App.IsConfigured && !App.HasData && !App.IsLoading)
            await App.LoadAsync();
    }

    private async Task Refresh() => await App.LoadAsync();

    private int NetRrValue() => App.RrHistory.Sum(s => s.RrDelta);
    private string NetRr() => $"{(NetRrValue() >= 0 ? "+" : "")}{NetRrValue()} RR";

    private string Swing()
    {
        if (App.RrHistory.Count == 0) return "—";
        int best = App.RrHistory.Max(s => s.RrDelta);
        int worst = App.RrHistory.Min(s => s.RrDelta);
        return $"+{best} / {worst}";
    }
}
