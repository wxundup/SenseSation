@page "/live"
@inject ILiveClient Client
@implements IDisposable

<PageTitle>SenseSation · Live Lobby</PageTitle>

<div class="page-head">
    <div>
        <h1>Live Lobby</h1>
        <div class="sub">
            <span class="live-dot @(Client.IsConnected ? "on" : "")"></span>
            @_status
        </div>
    </div>
    <button class="btn primary" @onclick="ScanNow" disabled="@_busy">
        @(_busy ? "Scanning…" : "↻ Rescan now")
    </button>
</div>

<div class="banner info">
    Reads only lobby metadata (names, ranks) from your local Riot client — the same data
    in-client trackers show. No positions or live in-round state. Auto-detects while Valorant is running.
</div>

@if (_env is not null)
{
    <div class="card" style="margin-bottom:16px">
        <div style="display:flex;gap:24px;flex-wrap:wrap;font-size:.88rem">
            <span><span class="live-dot @(_env.ValorantRunning ? "on" : "")"></span> Valorant process</span>
            <span><span class="live-dot @(_env.RiotClientRunning ? "on" : "")"></span> Riot Client</span>
            <span><span class="live-dot @(_env.LockfileExists ? "on" : "")"></span> Lockfile</span>
            <span class="muted">Auto-checking every @PollSeconds s</span>
        </div>
    </div>
}

@if (!string.IsNullOrEmpty(_error) && _lobby is null)
{
    <div class="banner warn">@_error</div>
    @if (_error.Contains("administrator"))
    {
        <div class="banner info">
            Fix: close SenseSation, right-click <strong>SenseSation.exe</strong> →
            <strong>Run as administrator</strong>. The Riot local API needs matching elevation.
        </div>
    }
}

@if (_lobby is not null)
{
    <div class="grid cols-2">
        <div class="card">
            <h3>Your Team · avg @TierName(_lobby.AverageAllyTier)</h3>
            <TeamTable Players="_lobby.Allies" OnSelect="ViewCareer" />
        </div>
        <div class="card">
            <h3>Enemy Team · avg @TierName(_lobby.AverageEnemyTier)</h3>
            @if (_lobby.Enemies.Count == 0)
            {
                <p class="muted">Enemy ranks become visible once the match starts (hidden during agent select).</p>
            }
            else
            {
                <TeamTable Players="_lobby.Enemies" OnSelect="ViewCareer" />
            }
        </div>
    </div>

    @if (_careerOpen)
    {
        <div class="card" style="margin-top:16px">
            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:6px">
                <h3 style="margin:0">Career · @(_career?.DisplayName ?? _careerName)</h3>
                <button class="btn" @onclick="() => _careerOpen = false">✕ Close</button>
            </div>

            @if (_careerLoading)
            {
                <div class="banner info"><span class="spinner"></span> &nbsp;Loading career…</div>
            }
            else if (_career is null)
            {
                <p class="muted">@(_careerError ?? "Couldn't load this player's career.")</p>
            }
            else
            {
                <div style="display:flex;gap:10px;flex-wrap:wrap;align-items:center;margin-bottom:12px">
                    <RankPill Rank="_career.Rank" />
                    <span class="chip">@_career.Recent.Count games</span>
                    <span class="chip @(_career.WinRate >= 50 ? "" : "")">@_career.WinRate.ToString("0")% WR · @_career.Wins W-@_career.Losses L</span>
                    <span class="chip">@_career.AvgKd.ToString("0.00") avg K/D</span>
                </div>
                @if (_career.Recent.Count == 0)
                {
                    <p class="muted">No recent competitive matches available.</p>
                }
                else
                {
                    <table>
                        <thead><tr><th>Result</th><th>Agent</th><th>Map</th><th>Score</th><th>K / D / A</th><th>HS%</th></tr></thead>
                        <tbody>
                            @foreach (var m in _career.Recent)
                            {
                                <tr>
                                    <td class="@ResultClass(m.Result)">@m.Result.ToString().ToUpper()</td>
                                    <td>@m.Agent</td><td>@m.Map</td>
                                    <td class="mono">@m.ScoreLabel</td>
                                    <td class="mono">@m.You.Kills / @m.You.Deaths / @m.You.Assists</td>
                                    <td class="mono">@m.You.HeadshotPct%</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            }
        </div>
    }
}
else if (!_busy)
{
    <div class="empty">
        <div class="big">◉</div>
        <p>@(_env?.LooksReachable == true
            ? "Connected — waiting for a match. Join a game to see lobby ranks."
            : "Start Valorant — this page will connect automatically.")</p>
    </div>
}

@code {
    private const int PollSeconds = 4;

    private LiveLobby? _lobby;
    private LiveEnvironment? _env;
    private bool _busy;
    private string _status = "Detecting…";
    private string? _error;
    private Timer? _timer;

    protected override void OnInitialized()
    {
        _timer = new Timer(async _ => await Tick(), null,
            TimeSpan.Zero, TimeSpan.FromSeconds(PollSeconds));
    }

    private async Task ScanNow() => await Tick(force: true);

    private async Task Tick(bool force = false)
    {
        if (_busy && !force) return;
        _busy = true;
        try
        {
            _env = Client.DetectEnvironment();

            if (_env.LooksReachable && !Client.IsConnected)
                await Client.ConnectAsync();

            if (Client.IsConnected)
                _lobby = await Client.GetCurrentLobbyAsync();

            _error = Client.LastError;
            _status = Client.IsConnected
                ? (_lobby is not null ? "In a match" : "Connected to local client")
                : _env.Describe();
        }
        catch (Exception ex) { _error = ex.Message; }
        finally
        {
            _busy = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private static string TierName(double avg) => RankTable.NameFor((int)Math.Round(avg));

    // ---- career viewer -------------------------------------------------------
    private bool _careerOpen;
    private bool _careerLoading;
    private string _careerName = "";
    private string? _careerError;
    private PlayerCareer? _career;

    private async Task ViewCareer(PlayerSummary p)
    {
        _careerOpen = true;
        _careerLoading = true;
        _career = null;
        _careerError = null;
        _careerName = string.IsNullOrEmpty(p.Name) ? "Player" : p.DisplayName;
        await InvokeAsync(StateHasChanged);
        try
        {
            _career = await Client.GetCareerAsync(p.Puuid);
            if (_career is null) _careerError = Client.LastError ?? "No career data.";
        }
        catch (Exception ex) { _careerError = ex.Message; }
        finally { _careerLoading = false; await InvokeAsync(StateHasChanged); }
    }

    private static string ResultClass(MatchResult r) => r switch
    {
        MatchResult.Win => "tag-win", MatchResult.Loss => "tag-loss", _ => "tag-draw"
    };

    public void Dispose() => _timer?.Dispose();
}
